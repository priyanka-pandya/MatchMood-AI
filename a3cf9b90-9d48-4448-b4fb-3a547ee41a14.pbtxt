        lines {
          text: "        helpIndicator.classList.add(\"hidden\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        headerSubtitle.textContent = \"\360\237\217\217 MI vs RR \342\200\242 LIVE\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
