    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>MatchMood AI</title>\n  \n  <!-- Tailwind CSS v4 CDN -->\n  <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\"></script>\n  \n  <!-- Font Integrations -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root {\n      --font-space: \'Space Grotesk\', sans-serif;\n      --font-inter: \'Inter\', sans-serif;\n      --font-mono: \'JetBrains Mono\', monospace;\n    }\n    \n    body {\n      font-family: var(--font-inter);\n      background-color: #0F0F1A;\n    }\n\n    /* Custom scrollbars */\n    ::-webkit-scrollbar {\n      width: 6px;\n    }\n    ::-webkit-scrollbar-track {\n      background: transparent;\n    }\n    ::-webkit-scrollbar-thumb {\n      background: rgba(255, 255, 255, 0.1);\n      border-radius: 999px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n      background: rgba(255, 255, 255, 0.25);\n    }\n\n    /* Animations */\n    @keyframes bounceIn {\n      0% {\n        transform: translateY(-200px) scale(0.3);\n        opacity: 0;\n      }\n      50% {\n        transform: translateY(20px) scale(1.1);\n        opacity: 0.9;\n      }\n      70% {\n        transform: translateY(-10px) scale(0.95);\n        opacity: 0.95;\n      }\n      100% {\n        transform: translateY(0) scale(1);\n        opacity: 1;\n      }\n    }\n\n    @keyframes fadeIn {\n      from { opacity: 0; }\n      to { opacity: 1; }\n    }\n\n    @keyframes fadeOut {\n      from { opacity: 1; }\n      to { opacity: 0; }\n    }\n\n    @keyframes shimmer {\n      0% {\n        background-position: -200% 0;\n      }\n      100% {\n        background-position: 200% 0;\n      }\n    }\n\n    @keyframes dotBounce {\n      0%, 100% {\n        transform: translateY(0);\n      }\n      50% {\n        transform: translateY(-6px);\n      }\n    }\n\n    @keyframes gateGlow {\n      0% {\n        box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);\n        filter: drop-shadow(0 0 2px rgba(74, 222, 128, 0.9));\n        transform: scale(1);\n      }\n      50% {\n        box-shadow: 0 0 0 10px rgba(74, 222, 128, 0);\n        filter: drop-shadow(0 0 10px rgba(74, 222, 128, 1));\n        transform: scale(1.3);\n      }\n      100% {\n        box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);\n        filter: drop-shadow(0 0 2px rgba(74, 222, 128, 0.9));\n        transform: scale(1);\n      }\n    }\n\n    @keyframes slideUp {\n      from {\n        transform: translateY(12px);\n        opacity: 0;\n      }\n      to {\n        transform: translateY(0);\n        opacity: 1;\n      }\n    }\n\n    .animate-bounce-in {\n      animation: bounceIn 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;\n    }\n\n    .animate-fade-in {\n      animation: fadeIn 0.4s ease-out forwards;\n    }\n\n    .animate-shimmer {\n      background: linear-gradient(90deg, #6B7280 25%, #E5E7EB 50%, #6B7280 75%);\n      background-size: 200% auto;\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      animation: shimmer 2.5s infinite linear;\n    }\n\n    .animate-typing-1 {\n      animation: dotBounce 0.6s infinite ease-in-out;\n    }\n    .animate-typing-2 {\n      animation: dotBounce 0.6s infinite ease-in-out;\n      animation-delay: 0.15s;\n    }\n    .animate-typing-3 {\n      animation: dotBounce 0.6s infinite ease-in-out;\n      animation-delay: 0.3s;\n    }\n\n    .gate-pulsing {\n      animation: gateGlow 1.5s infinite ease-in-out;\n    }\n\n    .tab-entering {\n      animation: slideUp 0.250s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n    }\n\n    /* Mobile Frame Styling for Desktop Viewport */\n    @media (min-width: 640px) {\n      .app-frame {\n        max-width: 480px;\n        height: 850px;\n        border: 8px solid #27273F;\n        border-radius: 40px;\n        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);\n        background-color: #F5F7FA;\n        position: relative;\n        overflow: hidden;\n      }\n    }\n\n    /* Button Tap Feel */\n    .active-scale:active {\n      transform: scale(0.96);\n      transition: transform 100ms ease;\n    }\n\n    /* Confetti/Fireworks Canvas */\n    #effects-canvas {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      pointer-events: none;\n      z-index: 40;\n    }\n  </style>\n</head>\n<body class=\"flex items-center justify-center min-h-screen p-0 sm:p-4 text-slate-800\">\n\n  <!-- ==============================================\n       SPLASH SCREEN\n       ============================================== -->\n  <div id=\"splash-screen\" class=\"fixed inset-0 bg-[#1C1C2E] z-50 flex flex-col items-center justify-center animate-fade-in\">\n    <div class=\"flex flex-col items-center text-center px-6\">\n      <!-- Bouncing Cricket Ball -->\n      <div class=\"text-7xl md:text-8xl animate-bounce-in mb-6 select-none filter drop-shadow-[0_10px_15px_rgba(0,0,0,0.3)]\">\n        \360\237\217\217\n      </div>\n      <!-- Logo Title -->\n      <h1 class=\"text-4xl md:text-5xl font-bold tracking-tight text-white mb-2\" style=\"font-family: var(--font-space);\">\n        MatchMood <span class=\"text-[#D4AF37]\">AI</span>\n      </h1>\n      <!-- Tagline -->\n      <p class=\"text-lg md:text-xl text-[#D4AF37] font-medium\" style=\"font-family: var(--font-space);\">\n        \"Feel the game. Find your way.\"\n      </p>\n    </div>\n    \n    <!-- Shimmering Footer -->\n    <div class=\"absolute bottom-16 select-none\">\n      <p class=\"text-sm font-semibold tracking-wider uppercase animate-shimmer\" style=\"font-family: var(--font-mono);\">\n        Powered by Gemini 1.5 Flash\n      </p>\n    </div>\n  </div>\n\n  <!-- ==============================================\n       MAIN APP CONTAINER (Mobile Frame simulation)\n       ============================================== -->\n  <div id=\"app-container\" class=\"hidden app-frame w-full h-screen sm:h-[850px] flex flex-col bg-[#F5F7FA] font-sans shadow-lg select-none\">\n    \n    <!-- Toast Message Container -->\n    <div id=\"toast-message\" class=\"absolute top-24 left-1/2 -translate-x-1/2 w-[90%] bg-red-600 text-white text-xs font-bold px-4 py-3 rounded-xl shadow-xl z-50 flex items-center justify-between pointer-events-none opacity-0 transition-all duration-300 transform -translate-y-4\">\n      <div class=\"flex items-center gap-2\">\n        <span>\360\237\224\221</span>\n        <span id=\"toast-text\">Please add your Gemini API key to continue</span>\n      </div>\n    </div>\n\n    <!-- Active Effects Canvas -->\n    <canvas id=\"effects-canvas\"></canvas>\n\n    <!-- Header & Config Section -->\n    <header class=\"bg-[#1C1C2E] text-white flex-none shrink-0 border-b border-[#2C2C42]\">\n      \n      <!-- API Key Dropdown Bar -->\n      <div id=\"api-key-container\" class=\"bg-[#141424] px-4 py-2 flex items-center justify-between gap-2 border-b border-[#242438]\">\n        <div id=\"api-key-input-wrapper\" class=\"w-full flex items-center gap-1.5 animate-fade-in\">\n          <span class=\"text-sm\">\360\237\224\221</span>\n          <input \n            type=\"password\" \n            id=\"api-key-input\" \n            placeholder=\"Gemini API Key...\" \n            class=\"bg-[#242438] text-white outline-none border border-slate-700/50 rounded-lg px-2.5 py-1 text-xs w-full focus:border-[#D4AF37] tracking-wider\"\n          />\n          <button \n            id=\"save-key-btn\" \n            class=\"bg-[#004C97] hover:bg-[#005cb8] text-white font-bold text-xs px-3 py-1 rounded-lg outline-none active-scale cursor-pointer\"\n          >\n            Save\n          </button>\n        </div>\n        \n        <!-- Ready Badge (Initially Hidden) -->\n        <div id=\"api-ready-wrapper\" class=\"hidden w-full flex items-center justify-between animate-fade-in\">\n          <span class=\"bg-emerald-500/15 border border-emerald-500/30 text-emerald-400 font-bold text-[11px] px-2.5 py-1 rounded-full flex items-center gap-1\">\n            <span class=\"w-2 h-2 rounded-full bg-emerald-400 animate-pulse\"></span>\n            \342\234\205 MatchMood AI Ready\n          </span>\n          <button \n            id=\"change-key-btn\" \n            class=\"text-slate-400 hover:text-white text-[11px] underline outline-none cursor-pointer\"\n          >\n            Reset Key\n          </button>\n        </div>\n      </div>\n\n      <!-- Header Title Bar -->\n      <div class=\"px-5 py-4 flex items-center justify-between\">\n        <div>\n          <h2 class=\"text-xl font-bold flex items-center gap-2 select-none\" style=\"font-family: var(--font-space);\">\n            <span class=\"text-[#D4AF37]\">MatchMood AI</span>\n          </h2>\n          <p id=\"header-subtitle\" class=\"text-xs text-slate-300 font-medium mt-0.5\">\n            \360\237\217\237 Stadium Navigator \342\200\242 Wankhede\n          </p>\n        </div>\n        <div class=\"flex items-center gap-1 bg-[#2C2C42] px-2.5 py-1 rounded-full text-[10px] font-bold text-amber-400 border border-amber-500/20 uppercase tracking-widest\">\n          \342\232\241 DEMO\n        </div>\n      </div>\n    </header>\n\n    <!-- ==============================================\n         TAB 1: HELP CONTENT (Wankhede Stadium Navigator)\n         ============================================== -->\n    <div id=\"help-tab-content\" class=\"flex-1 overflow-y-auto p-4 flex flex-col gap-4 tab-entering\">\n      \n      <!-- Stadium Map Wrapper Card -->\n      <div class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-4\">\n        <h3 class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 select-none\">\n          \360\237\217\237 Interactive Stadium Layout\n        </h3>\n        \n        <!-- SVG Stadium Graphic -->\n        <div class=\"w-full flex justify-center py-2 bg-slate-950/5 rounded-xl border border-slate-200/55 p-1 relative overflow-hidden\">\n          <svg viewBox=\"0 0 320 220\" class=\"w-full max-w-[280px] drop-shadow-md select-none\">\n            <!-- Outermost structure stand boundary -->\n            <ellipse cx=\"160\" cy=\"110\" rx=\"140\" ry=\"90\" fill=\"none\" stroke=\"#2C2C42\" stroke-width=\"6\" />\n            <ellipse cx=\"160\" cy=\"110\" rx=\"136\" ry=\"86\" fill=\"none\" stroke=\"#3D3D5E\" stroke-width=\"2\" />\n            \n            <!-- Stadium Stands Base Fill -->\n            <ellipse cx=\"160\" cy=\"110\" rx=\"125\" ry=\"75\" fill=\"#E2E8F0\" opacity=\"0.15\" />\n            \n            <!-- Stadium Stands Ring -->\n            <ellipse cx=\"160\" cy=\"110\" rx=\"115\" ry=\"65\" fill=\"none\" stroke=\"#94A3B8\" stroke-width=\"12\" />\n            \n            <!-- Boundaries -->\n            <ellipse cx=\"160\" cy=\"110\" rx=\"98\" ry=\"48\" fill=\"none\" stroke=\"#CBD5E1\" stroke-width=\"1\" stroke-dasharray=\"2 3\" />\n            <ellipse cx=\"160\" cy=\"110\" rx=\"90\" ry=\"40\" fill=\"#2E7D32\" />\n            \n            <!-- Pitch Oval Center -->\n            <rect x=\"145\" y=\"100\" width=\"30\" height=\"20\" rx=\"2\" fill=\"#D4AF37\" stroke=\"#fff\" stroke-width=\"0.5\" transform=\"rotate(25 160 110)\" />\n            \n            <!-- Green pitch oval markings -->\n            <ellipse cx=\"160\" cy=\"110\" rx=\"80\" ry=\"32\" fill=\"none\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"1\" />\n            \n            <!-- GATES (As individual Interactive Gs with glow ring effects) -->\n            <!-- Gate 1 West (Left) -->\n            <g id=\"gate-1-group\" class=\"cursor-pointer\">\n              <ellipse cx=\"20\" cy=\"110\" rx=\"14\" ry=\"14\" fill=\"rgba(255,255,255,0.7)\" opacity=\"0\" />\n              <circle id=\"gate-1-pulse\" cx=\"20\" cy=\"110\" r=\"12\" fill=\"none\" stroke=\"#4ADE80\" stroke-width=\"1\" class=\"opacity-0\" />\n              <circle id=\"gate-1-dot\" cx=\"20\" cy=\"110\" r=\"7\" fill=\"#E53935\" class=\"transition-colors duration-300\" />\n              <text x=\"20\" y=\"113\" fill=\"white\" font-size=\"8\" font-weight=\"bold\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n              <text x=\"21\" y=\"94\" fill=\"#1e293b\" font-size=\"8\" font-weight=\"bold\" text-anchor=\"start\">West Gate 1</text>\n            </g>\n\n            <!-- Gate 2 South (Bottom) -->\n            <g id=\"gate-2-group\" class=\"cursor-pointer\">\n              <ellipse cx=\"160\" cy=\"195\" rx=\"14\" ry=\"14\" fill=\"rgba(255,255,255,0.7)\" opacity=\"0\" />\n              <circle id=\"gate-2-pulse\" cx=\"160\" cy=\"195\" r=\"12\" fill=\"none\" stroke=\"#4ADE80\" stroke-width=\"1\" class=\"opacity-0\" />\n              <circle id=\"gate-2-dot\" cx=\"160\" cy=\"195\" r=\"7\" fill=\"#1565C0\" class=\"transition-colors duration-300\" />\n              <text x=\"160\" y=\"198\" fill=\"white\" font-size=\"8\" font-weight=\"bold\" font-family=\"sans-serif\" text-anchor=\"middle\">2</text>\n              <text x=\"160\" y=\"213\" fill=\"#1e293b\" font-size=\"8\" font-weight=\"bold\" text-anchor=\"middle\">South Gate 2</text>\n            </g>\n\n            <!-- Gate 3 North-East (Top-Right) -->\n            <g id=\"gate-3-group\" class=\"cursor-pointer\">\n              <ellipse cx=\"275\" cy=\"45\" rx=\"14\" ry=\"14\" fill=\"rgba(255,255,255,0.7)\" opacity=\"0\" />\n              <circle id=\"gate-3-pulse\" cx=\"275\" cy=\"45\" r=\"12\" fill=\"none\" stroke=\"#4ADE80\" stroke-width=\"1\" class=\"opacity-0\" />\n              <circle id=\"gate-3-dot\" cx=\"275\" cy=\"45\" r=\"7\" fill=\"#F9A825\" class=\"transition-colors duration-300\" />\n              <text x=\"275\" y=\"48\" fill=\"white\" font-size=\"8\" font-weight=\"bold\" font-family=\"sans-serif\" text-anchor=\"middle\">3</text>\n              <text x=\"275\" y=\"32\" fill=\"#1e293b\" font-size=\"8\" font-weight=\"bold\" text-anchor=\"middle\">NE Gate 3</text>\n            </g>\n\n            <!-- Gate 4 South-East (Bottom-Right) -->\n            <g id=\"gate-4-group\" class=\"cursor-pointer\">\n              <ellipse cx=\"275\" cy=\"165\" rx=\"14\" ry=\"14\" fill=\"rgba(255,255,255,0.7)\" opacity=\"0\" />\n              <circle id=\"gate-4-pulse\" cx=\"275\" cy=\"165\" r=\"12\" fill=\"none\" stroke=\"#4ADE80\" stroke-width=\"1\" class=\"opacity-0\" />\n              <circle id=\"gate-4-dot\" cx=\"275\" cy=\"165\" r=\"7\" fill=\"#E91E8C\" class=\"transition-colors duration-300\" />\n              <text x=\"275\" y=\"168\" fill=\"white\" font-size=\"8\" font-weight=\"bold\" font-family=\"sans-serif\" text-anchor=\"middle\">4</text>\n              <text x=\"275\" y=\"183\" fill=\"#1e293b\" font-size=\"8\" font-weight=\"bold\" text-anchor=\"middle\">SE Gate 4</text>\n            </g>\n          </svg>\n        </div>\n        <p class=\"text-[10px] text-center text-slate-400 font-medium select-none\">\n          \360\237\222\241 Map pulses gate when identified in the MatchMood AI answers.\n        </p>\n      </div>\n\n      <!-- Quick Navigation Shortcuts -->\n      <div class=\"grid grid-cols-2 gap-2 flex-none shrink-0 text-white select-none\">\n        <button onclick=\"sendShortcut(\'\360\237\223\215 My Gate\', \'Which gate should I use for Section A, Row 12?\')\" class=\"active-scale cursor-pointer bg-[#004C97] hover:bg-[#003c77] rounded-xl flex items-center justify-center p-3 font-bold text-center text-sm gap-2 outline-none h-12 shadow-sm\">\n          <span>\360\237\223\215</span> My Gate\n        </button>\n        <button onclick=\"sendShortcut(\'\360\237\215\224 Nearest Food\', \'Where is the nearest food stall from Gate 3?\')\" class=\"active-scale cursor-pointer bg-emerald-600 hover:bg-emerald-700 rounded-xl flex items-center justify-center p-3 font-bold text-center text-sm gap-2 outline-none h-12 shadow-sm\">\n          <span>\360\237\215\224</span> Near Food\n        </button>\n        <button onclick=\"sendShortcut(\'\360\237\232\273 Restroom\', \'Where is the nearest restroom to Gate 3?\')\" class=\"active-scale cursor-pointer bg-slate-750 hover:bg-slate-800 rounded-xl flex items-center justify-center p-3 font-bold text-center text-sm gap-2 text-slate-700 border border-slate-200 bg-white rounded-xl shadow-sm h-12\">\n          <span>\360\237\232\273</span> Restroom\n        </button>\n        <button onclick=\"sendShortcut(\'\360\237\217\245 First Aid\', \'Where is the First Aid centre?\')\" class=\"active-scale cursor-pointer bg-[#E53935] hover:bg-[#c62828] rounded-xl flex items-center justify-center p-3 font-bold text-center text-sm gap-2 outline-none h-12 shadow-sm\">\n          <span>\360\237\217\245</span> First Aid\n        </button>\n      </div>\n\n      <!-- Chat Area -->\n      <div class=\"flex-1 bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col overflow-hidden min-h-[220px]\">\n        <div id=\"help-chat-messages\" class=\"flex-1 overflow-y-auto p-4 flex flex-col gap-3\">\n          <!-- Initial AI Welcome Msg -->\n          <div class=\"flex flex-col gap-1 items-start text-left max-w-[85%] self-start animate-fade-in animate-slide-up\">\n            <span class=\"text-[10px] text-slate-400 font-bold ml-1 tracking-wider uppercase flex items-center gap-1\">\n              \342\234\250 MatchMood AI \342\200\242 Gemini 1.5 Flash\n            </span>\n            <div class=\"bg-slate-100 text-slate-800 rounded-2xl rounded-tl-sm px-4 py-3 text-sm leading-relaxed font-normal shadow-xs border border-slate-200/50\">\n              Welcome to the Wankhede Stadium! \360\237\217\237\357\270\217 I can help find gates, seats, food, or first aid. Tap a shortcut above or type a custom question! \360\237\222\231\n            </div>\n          </div>\n        </div>\n\n        <!-- Chat Input Bar -->\n        <div class=\"border-t border-slate-100 p-2 flex items-center gap-2 bg-slate-50/80\">\n          <input \n            type=\"text\" \n            id=\"help-chat-input\" \n            placeholder=\"Ask stadium navigator query...\" \n            class=\"flex-1 bg-white border border-slate-200 rounded-full px-4 py-2.5 text-xs outline-none focus:border-[#004C97] text-slate-800\"\n          />\n          <button \n            id=\"help-chat-send\" \n            class=\"active-scale outline-none cursor-pointer bg-[#004C97] hover:bg-[#003c77] rounded-full p-2.5 text-white flex items-center justify-center shadow-md shrink-0 focus:ring-2 focus:ring-[#004C97]/30 h-[38px] w-[38px]\"\n          >\n            <!-- Send SVG -->\n            <svg class=\"w-4 h-4 transform rotate-45 -mr-0.5 mt-0.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 19l9 2-9-18-9 18 9-2zm0 0v-8\"></path>\n            </svg>\n          </button>\n        </div>\n      </div>\n    </div>\n\n\n    <!-- ==============================================\n         TAB 2: FAN CONTENT (IPL Fan Zone / Live reactions)\n         ============================================== -->\n    <div id=\"fan-tab-content\" class=\"hidden flex-1 overflow-y-auto p-4 flex flex-col gap-4 tab-entering\">\n      \n      <!-- Live Score Banner Overlay -->\n      <div class=\"bg-gradient-to-r from-[#004C97] to-[#1C1C2E] rounded-2xl shadow-md border border-slate-800 p-4 text-white relative overflow-hidden select-none flex-none shrink-0\">\n        <!-- Abstract BG Stadium light effect -->\n        <div class=\"absolute -right-10 -top-10 w-24 h-24 bg-blue-500/20 rounded-full blur-2xl\"></div>\n        <div class=\"absolute -left-10 -bottom-10 w-24 h-24 bg-[#E91E8C]/15 rounded-full blur-2xl\"></div>\n        \n        <div class=\"flex items-center justify-between mb-2\">\n          <div class=\"flex items-center gap-1.5 uppercase font-bold tracking-widest text-[11px] bg-red-600 px-2 py-0.5 rounded-full shadow-xs\">\n            <span class=\"w-2 h-2 rounded-full bg-white animate-pulse\"></span>\n            MI vs RR \342\200\242 Live\n          </div>\n          <span class=\"text-[10px] text-slate-300 font-bold\" style=\"font-family: var(--font-mono);\">\n            WANKHEDE STADIUM\n          </span>\n        </div>\n        \n        <!-- Score and status -->\n        <div class=\"flex items-baseline justify-between py-1 border-b border-white/10 mb-2\">\n          <h2 class=\"text-3xl font-black tracking-tight font-mono text-[#D4AF37]\">\n            142/4 <span class=\"text-xs font-semibold text-slate-300\">(16.2 ov)</span>\n          </h2>\n          <span class=\"text-xs font-bold text-pink-400\">RR yet to bat</span>\n        </div>\n\n        <div class=\"flex items-center justify-between text-[11px] text-slate-300 font-medium\">\n          <span class=\"flex items-center gap-1\">\360\237\223\215 Wankhede Pitch: Batter friendly</span>\n          <span>MatchMood AI is watching with you \360\237\221\201</span>\n        </div>\n      </div>\n\n      <!-- Celebration Buttons -->\n      <div class=\"flex flex-col gap-2 flex-none shrink-0 select-none\">\n        <!-- Wicket celebration -->\n        <button id=\"wicket-btn\" class=\"active-scale cursor-pointer bg-[#E53935] hover:bg-[#c62828] text-white font-black rounded-2xl py-4 flex items-center justify-center gap-3 transition-all duration-100 shadow-md h-16 uppercase italic tracking-wider text-lg border-b-4 border-red-800\">\n          \360\237\217\217 WICKET!\n        </button>\n        <!-- Six celebration -->\n        <button id=\"six-btn\" class=\"active-scale cursor-pointer bg-[#1565C0] hover:bg-[#0d47a1] text-white font-black rounded-2xl py-4 flex items-center justify-center gap-3 transition-all duration-100 shadow-md h-16 uppercase italic tracking-wider text-lg border-b-4 border-blue-900\">\n          \360\237\222\245 SIX!\n        </button>\n        <!-- MI Chant generation -->\n        <button id=\"chant-btn\" class=\"active-scale cursor-pointer bg-[#F9A825] hover:bg-[#e65100] text-[#1C1C2E] font-black rounded-2xl py-4 flex items-center justify-center gap-3 transition-all duration-100 shadow-md h-16 uppercase italic tracking-wider text-md border-b-4 border-amber-700\">\n          \360\237\216\265 Generate MI Chant\n        </button>\n      </div>\n\n      <!-- Dynamic Reaction Card Container -->\n      <div id=\"dynamic-reaction-card\" class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-4 transition-all duration-300 hidden\">\n        <div class=\"flex items-center justify-between mb-2\">\n          <span class=\"text-[10px] text-slate-500 font-bold tracking-wider uppercase flex items-center gap-1\">\n            \342\234\250 MatchMood AI \342\200\242 Gemini 1.5 Flash\n          </span>\n          <span id=\"reaction-type-badge\" class=\"text-[9px] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-wider\"></span>\n        </div>\n        <!-- Card Text -->\n        <div id=\"reaction-text\" class=\"text-slate-800 text-sm font-semibold italic border-l-4 pl-3 py-1\"></div>\n        \n        <!-- Copy button (Only visible for Chant responses) -->\n        <div id=\"copy-chant-container\" class=\"mt-3 flex items-center justify-end hidden\">\n          <p id=\"copy-feedback-label\" class=\"text-[10px] text-emerald-600 font-bold mr-3 opacity-0 transition-opacity duration-300\">Chant Copied!</p>\n          <button id=\"copy-chant-btn\" class=\"active-scale outline-none cursor-pointer bg-slate-900 hover:bg-black text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center gap-1\">\n            \360\237\223\213 Copy Chant\n          </button>\n        </div>\n      </div>\n\n      <!-- Live Match Prediction Section -->\n      <div class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-4 flex flex-col gap-3\">\n        <div>\n          <h3 class=\"text-xs font-bold text-slate-500 uppercase tracking-wider mb-0.5 flex items-center gap-1.5\">\n            <span>\342\232\241</span> Who wins tonight?\n          </h3>\n          <p class=\"text-[11px] text-slate-400\">\n            Ask Gemini\'s crazy fan persona to run high-hype win-chance percentage analysis!\n          </p>\n        </div>\n        \n        <!-- Input section -->\n        <div class=\"flex gap-2\">\n          <input \n            type=\"text\" \n            id=\"predict-input\" \n            placeholder=\"Type context or simply tap predict...\" \n            class=\"flex-1 bg-slate-50 border border-slate-200 rounded-xl px-3.5 py-2.5 text-xs outline-none focus:border-[#F9A825] text-slate-800\"\n          />\n          <button \n            id=\"predict-btn\" \n            class=\"active-scale outline-none cursor-pointer bg-[#F9A825] text-[#1C1C2E] font-bold text-xs px-4 rounded-xl flex items-center justify-center gap-1.5 shrink-0\"\n          >\n            \342\232\241 Predict\n          </button>\n        </div>\n\n        <!-- Predict Output Loader -->\n        <div class=\"flex justify-center py-2 h-14 content-center hidden\" id=\"predict-loader\">\n          <!-- Bouncing dots loader -->\n          <div class=\"flex items-center justify-center gap-1.5 py-2 px-3 bg-amber-50 rounded-xl\">\n            <span class=\"text-xs font-bold text-amber-600\">Checking crystals...</span>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-amber-500 animate-typing-1\"></div>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-amber-500 animate-typing-2\"></div>\n            <div class=\"w-1.5 h-1.5 rounded-full bg-amber-500 animate-typing-3\"></div>\n          </div>\n        </div>\n\n        <!-- Predictive output display card -->\n        <div id=\"predict-output\" class=\"bg-amber-50/70 border border-amber-200/50 rounded-xl p-3.5 hidden\">\n          <div class=\"flex items-center justify-between mb-1.5\">\n            <span class=\"text-[10px] text-amber-700 font-extrabold tracking-wider uppercase flex items-center gap-1 select-none\">\n              \342\234\250 MatchMood Prediction\n            </span>\n            <span id=\"win-pct-badge\" class=\"bg-amber-100 border border-amber-300 text-amber-800 font-mono font-bold text-[11px] px-2 py-0.5 rounded-md\"></span>\n          </div>\n          <!-- Predictive content output text -->\n          <p id=\"predict-text\" class=\"text-slate-800 text-xs py-0.5 leading-relaxed font-semibold\"></p>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- ==============================================\n         BOTTOM NAVIGATION BAR (2 TABS)\n         ============================================== -->\n    <nav class=\"bg-white border-t border-slate-200 flex items-center justify-around py-2.5 flex-none shrink-0 z-10 select-none shadow-md\">\n      <!-- Help Tab Navigator -->\n      <button \n        id=\"tab-help-btn\" \n        onClick=\"switchTab(\'help\')\" \n        class=\"flex-1 py-1 flex flex-col items-center justify-center opacity-100 transition-all duration-200 border-none outline-none relative cursor-pointer\"\n      >\n        <span class=\"text-lg mb-0.5\">\360\237\217\237</span>\n        <span class=\"text-[11px] font-bold tracking-wide text-[#004C97]\">Help Nav</span>\n        <span id=\"tab-help-indicator\" class=\"absolute bottom-[-10px] w-12 h-[3px] bg-[#D4AF37] rounded-full\"></span>\n      </button>\n\n      <!-- Fan Corner Tab Navigator -->\n      <button \n        id=\"tab-fan-btn\" \n        onClick=\"switchTab(\'fan\')\" \n        class=\"flex-1 py-1 flex flex-col items-center justify-center opacity-40 transition-all duration-200 border-none outline-none relative cursor-pointer\"\n      >\n        <span class=\"text-lg mb-0.5\">\360\237\216\211</span>\n        <span class=\"text-[11px] font-bold tracking-wide text-slate-500\">Fan corner</span>\n        <span id=\"tab-fan-indicator\" class=\"absolute bottom-[-10px] w-12 h-[3px] bg-[#D4AF37] rounded-full hidden\"></span>\n      </button>\n    </nav>\n\n    <!-- Hackathon Branding Footer Info -->\n    <footer class=\"bg-[#1C1C2E] py-1.5 text-center text-[10px] text-slate-400 flex-none shrink-0 tracking-wider\">\n      MatchMood AI \342\200\224 Powered by Gemini 1.5 Flash | GDG Rajkot\n    </footer>\n\n  </div>\n\n  <!-- JavaScript logic definitions -->\n  <script>\n    // System configurations\n    let api_key = \"\";\n    let currentTab = \"help\";\n    let isRequesting = false;\n\n    // References to Map elements\n    const gatesMark = {\n      1: { dot: \"gate-1-dot\", pulse: \"gate-1-pulse\" },\n      2: { dot: \"gate-2-dot\", pulse: \"gate-2-pulse\" },\n      3: { dot: \"gate-3-dot\", pulse: \"gate-3-pulse\" },\n      4: { dot: \"gate-4-dot\", pulse: \"gate-4-pulse\" }\n    };\n\n    // Splash Screen Timeout\n    setTimeout(() => {\n      const splashScreen = document.getElementById(\"splash-screen\");\n      const appContainer = document.getElementById(\"app-container\");\n      \n      // Animate fadeout\n      splashScreen.style.transition = \"opacity 400ms ease\";\n      splashScreen.style.opacity = \"0\";\n      \n      setTimeout(() => {\n        splashScreen.style.display = \"none\";\n        appContainer.style.display = \"flex\";\n        appContainer.classList.add(\"animate-fade-in\");\n        \n        // Auto-scroll chat initially\n        scrollChatToBottom();\n        \n        // Load API Key if exists\n        loadSavedKey();\n      }, 400);\n    }, 2500);\n\n    // Dynamic Tab Switch logic\n    function switchTab(tab) {\n      if (currentTab === tab) return;\n      currentTab = tab;\n\n      const helpContent = document.getElementById(\"help-tab-content\");\n      const fanContent = document.getElementById(\"fan-tab-content\");\n      const helpBtn = document.getElementById(\"tab-help-btn\");\n      const fanBtn = document.getElementById(\"tab-fan-btn\");\n      \n      const helpIndicator = document.getElementById(\"tab-help-indicator\");\n      const fanIndicator = document.getElementById(\"tab-fan-indicator\");\n      const headerSubtitle = document.getElementById(\"header-subtitle\");\n\n      if (tab === \"help\") {\n        helpContent.classList.remove(\"hidden\");\n        fanContent.classList.add(\"hidden\");\n        \n        helpBtn.style.opacity = \"1\";\n        helpBtn.querySelector(\"span:last-child\").style.color = \"#004C97\";\n        fanBtn.style.opacity = \"0.4\";\n        fanBtn.querySelector(\"span:last-child\").style.color = \"#64748b\";\n\n        helpIndicator.classList.remove(\"hidden\");\n        fanIndicator.classList.add(\"hidden\");\n\n        headerSubtitle.textContent = \"\360\237\217\237 Stadium Navigator \342\200\242 Wankhede\";\n      } else {\n        helpContent.classList.add(\"hidden\");\n        fanContent.classList.remove(\"hidden\");\n        \n        fanBtn.style.opacity = \"1\";\n        fanBtn.querySelector(\"span:last-child\").style.color = \"#004C97\";\n        helpBtn.style.opacity = \"0.4\";\n        helpBtn.querySelector(\"span:last-child\").style.color = \"#64748b\";\n\n        fanIndicator.classList.remove(\"hidden\");\n        helpIndicator.classList.add(\"hidden\");\n\n        headerSubtitle.textContent = \"\360\237\217\217 MI vs RR \342\200\242 LIVE\";\n      }\n    }\n\n    // Canvas configuration for Confetti / Fireworks\n    const canvas = document.getElementById(\"effects-canvas\");\n    const ctx = canvas.getContext(\"2d\");\n    let animationFrameId = null;\n\n    let particles = [];\n    let waves = [];\n\n    // Resize canvas to match container frame context scale\n    function resizeCanvas() {\n      const parent = canvas.parentElement;\n      canvas.width = parent.clientWidth;\n      canvas.height = parent.clientHeight;\n    }\n    window.addEventListener(\"resize\", resizeCanvas);\n    // Initial resize inside frame context\n    setTimeout(resizeCanvas, 3000);\n\n    // RequestAnimationFrame Game Loop\n    function updateEffects() {\n      ctx.clearRect(0, 0, canvas.width, canvas.height);\n      \n      // Update particles\n      particles = particles.filter(p => {\n        p.x += p.vx;\n        p.y += p.vy;\n        p.vy += p.gravity;\n        p.alpha -= p.fade;\n        p.rotation += p.rotationSpeed;\n        \n        if (p.alpha <= 0 || p.y > canvas.height) return false;\n        \n        ctx.save();\n        ctx.translate(p.x, p.y);\n        ctx.rotate(p.rotation);\n        ctx.fillStyle = p.color;\n        \n        ctx.beginPath();\n        if (p.isSpark) {\n          // Draw firework star lines\n          ctx.strokeStyle = p.color;\n          ctx.lineWidth = p.lineWidth || 2;\n          ctx.beginPath();\n          ctx.moveTo(-p.size, 0);\n          ctx.lineTo(p.size, 0);\n          ctx.stroke();\n        } else {\n          // Draw Confetti shapes\n          ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);\n        }\n        ctx.restore();\n        return true;\n      });\n\n      if (particles.length > 0) {\n        animationFrameId = requestAnimationFrame(updateEffects);\n      } else {\n        animationFrameId = null;\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n      }\n    }\n\n    function triggerConfetti() {\n      resizeCanvas();\n      particles = [];\n      const colors = [\"#004C97\", \"#D4AF37\", \"#E91E8C\", \"#E53935\", \"#1565C0\", \"#F9A825\", \"#4ADE80\", \"#C084FC\"];\n      \n      const particleCount = 80;\n      for (let i = 0; i < particleCount; i++) {\n        // Spawn particles towards bottom center blowing upwards\n        particles.push({\n          x: canvas.width / 2 + (Math.random() * 60 - 30),\n          y: canvas.height * 0.9,\n          vx: Math.random() * 8 - 4,\n          vy: -(Math.random() * 12 + 8),\n          gravity: 0.35,\n          alpha: 1,\n          fade: Math.random() * 0.005 + 0.005,\n          rotation: Math.random() * Math.PI * 2,\n          rotationSpeed: Math.random() * 0.1 - 0.05,\n          color: colors[Math.floor(Math.random() * colors.length)],\n          size: Math.random() * 8 + 6,\n          isSpark: false\n        });\n      }\n      \n      if (!animationFrameId) {\n        animationFrameId = requestAnimationFrame(updateEffects);\n      }\n    }\n\n    function triggerFireworks() {\n      resizeCanvas();\n      particles = [];\n      const colors = [\"#004C97\", \"#D4AF37\", \"#E91E8C\", \"#1565C0\", \"#F9A825\", \"#ffffff\"];\n      \n      const burstX = canvas.width / 2;\n      const burstY = canvas.height * 0.45; // Burst center\n      const rayCount = 12;\n\n      for (let j = 0; j < 3; j++) { // Multi layered bursts\n        const baseColor = colors[Math.floor(Math.random() * colors.length)];\n        const velocityScale = 3.5 + (j * 1.5);\n        for (let i = 0; i < rayCount; i++) {\n          const angle = (i * Math.PI * 2) / rayCount;\n          particles.push({\n            x: burstX,\n            y: burstY,\n            vx: Math.cos(angle) * (Math.random() * 2 + velocityScale),\n            vy: Math.sin(angle) * (Math.random() * 2 + velocityScale),\n            gravity: 0.1,\n            alpha: 1,\n            fade: 0.015 + (Math.random() * 0.005),\n            rotation: angle,\n            rotationSpeed: 0,\n            color: baseColor,\n            size: Math.random() * 10 + 8,\n            isSpark: true,\n            lineWidth: 2.5\n          });\n        }\n      }\n      \n      if (!animationFrameId) {\n        animationFrameId = requestAnimationFrame(updateEffects);\n      }\n    }\n\n    // API Key Storage & Handling\n    const saveKeyBtn = document.getElementById(\"save-key-btn\");\n    const changeKeyBtn = document.getElementById(\"change-key-btn\");\n    const apiKeyInput = document.getElementById(\"api-key-input\");\n    const apiKeysContainer = document.getElementById(\"api-key-container\");\n    const apiKeyWrapper = document.getElementById(\"api-key-input-wrapper\");\n    const apiReadyWrapper = document.getElementById(\"api-ready-wrapper\");\n\n    function loadSavedKey() {\n      const savedKey = localStorage.getItem(\"matchmood_api_key\");\n      // Also check platform env backup\n      const envKey = \"GEMINI_API_KEY_ENV\"; \n      \n      if (savedKey) {\n        api_key = savedKey;\n        setKeyReadyUI();\n      } else {\n        // If not explicit in client, don\'t auto crash but show input key bar\n        setKeyInputUI();\n      }\n    }\n\n    function setKeyReadyUI() {\n      apiKeyWrapper.classList.add(\"hidden\");\n      apiReadyWrapper.classList.remove(\"hidden\");\n    }\n\n    function setKeyInputUI() {\n      apiKeyWrapper.classList.remove(\"hidden\");\n      apiReadyWrapper.classList.add(\"hidden\");\n      apiKeyInput.value = api_key;\n    }\n\n    saveKeyBtn.addEventListener(\"click\", () => {\n      const keyInput = apiKeyInput.value.trim();\n      if (!keyInput) {\n        showToast(\"\360\237\224\221 Please enter a valid Gemini API key!\");\n        return;\n      }\n      api_key = keyInput;\n      localStorage.setItem(\"matchmood_api_key\", keyInput);\n      setKeyReadyUI();\n    });\n\n    changeKeyBtn.addEventListener(\"click\", () => {\n      api_key = \"\";\n      localStorage.removeItem(\"matchmood_api_key\");\n      setKeyInputUI();\n    });\n\n    // Elegant Custom Toast Catcher\n    function showToast(message) {\n      const toast = document.getElementById(\"toast-message\");\n      const text = document.getElementById(\"toast-text\");\n      text.textContent = message;\n      \n      toast.style.opacity = \"1\";\n      toast.style.transform = \"translate(-1/2, 0)\";\n      \n      setTimeout(() => {\n        toast.style.opacity = \"0\";\n        toast.style.transform = \"translate(-1/2, -16px)\";\n      }, 4000);\n    }\n\n    // Stadium Map Interaction - Pulse active Gate\n    function pulseGateOnMap(gateNum) {\n      // Clear existing pulses for safety\n      for (const key in gatesMark) {\n        const pulse = document.getElementById(gatesMark[key].pulse);\n        const dot = document.getElementById(gatesMark[key].dot);\n        pulse.classList.add(\"opacity-0\");\n        pulse.classList.remove(\"gate-pulsing\");\n        dot.setAttribute(\"fill\", key === \"1\" ? \"#E53935\" : key === \"2\" ? \"#1565C0\" : key === \"3\" ? \"#F9A825\" : \"#E91E8C\"); // default colors\n      }\n\n      const activePulse = document.getElementById(gatesMark[gateNum].pulse);\n      const activeDot = document.getElementById(gatesMark[gateNum].dot);\n      \n      if (activePulse) {\n        activePulse.classList.remove(\"opacity-0\");\n        activePulse.classList.add(\"gate-pulsing\");\n        // Glow in vibrant emerald neon green\n        activeDot.setAttribute(\"fill\", \"#2ecc71\");\n        \n        // Remove glow pulse after 6.5s to keep map clean\n        setTimeout(() => {\n          activePulse.classList.remove(\"gate-pulsing\");\n          activePulse.classList.add(\"opacity-0\");\n          activeDot.setAttribute(\"fill\", gateNum === 1 ? \"#E53935\" : gateNum === 2 ? \"#1565C0\" : gateNum === 3 ? \"#F9A825\" : \"#E91E8C\");\n        }, 6500);\n      }\n    }\n\n    // Watch text output and link gate maps\n    function checkMapTriggerFromText(text) {\n      const parsedText = text.toLowerCase();\n      if (parsedText.includes(\"gate 1\") || parsedText.includes(\"gate-1\")) {\n        pulseGateOnMap(1);\n      } else if (parsedText.includes(\"gate 2\") || parsedText.includes(\"gate-2\")) {\n        pulseGateOnMap(2);\n      } else if (parsedText.includes(\"gate 3\") || parsedText.includes(\"gate-3\")) {\n        pulseGateOnMap(3);\n      } else if (parsedText.includes(\"gate 4\") || parsedText.includes(\"gate-4\")) {\n        pulseGateOnMap(4);\n      }\n    }\n\n    // Auto-scroll chat area correctly\n    const chatContainer = document.getElementById(\"help-chat-messages\");\n    function scrollChatToBottom() {\n      setTimeout(() => {\n        chatContainer.scrollTop = chatContainer.scrollHeight;\n      }, 50);\n    }\n\n    // Direct fetch call to Gemini API\n    async function fetchGeminiAPI(prompt, systemInstruction) {\n      if (!api_key) {\n        showToast(\"\360\237\224\221 Please add your Gemini API key to continue\");\n        // Shake input key as direct reminder\n        apiKeyInput.classList.add(\"ring-2\", \"ring-red-500\", \"animate-pulse\");\n        setTimeout(() => {\n          apiKeyInput.classList.remove(\"ring-2\", \"ring-red-500\", \"animate-pulse\");\n        }, 2000);\n        throw new Error(\"No API key\");\n      }\n\n      const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${api_key}`;\n      \n      // Setup Controller for 8s Custom Timeout requirement\n      const controller = new AbortController();\n      const timeoutId = setTimeout(() => controller.abort(), 8000);\n\n      const requestPayload = {\n        contents: [\n          {\n            parts: [{ text: prompt }]\n          }\n        ]\n      };\n\n      if (systemInstruction) {\n        requestPayload.systemInstruction = {\n          parts: [{ text: systemInstruction }]\n        };\n      }\n\n      try {\n        const response = await fetch(endpoint, {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify(requestPayload),\n          signal: controller.signal\n        });\n\n        clearTimeout(timeoutId);\n\n        if (!response.ok) {\n          throw new Error(`HTTP Error Status: ${response.status}`);\n        }\n\n        const data = await response.json();\n        const outputText = data?.candidates?.[0]?.content?.parts?.[0]?.text;\n        \n        if (!outputText) {\n          throw new Error(\"Empty payload from server\");\n        }\n\n        return outputText;\n      } catch (error) {\n        clearTimeout(timeoutId);\n        \n        if (error.name === \"AbortError\") {\n          throw new Error(\"TIMEOUT\");\n        } else {\n          throw error;\n        }\n      }\n    }\n\n    // Help Nav Core - Append Dynamic Bubbles\n    function appendUserMessage(text) {\n      const msgDiv = document.createElement(\"div\");\n      msgDiv.className = \"flex flex-col gap-1 items-end text-right max-w-[85%] self-end animate-fade-in animate-slide-up\";\n      msgDiv.innerHTML = `\n        <span class=\"text-[9px] text-slate-400 font-bold mr-1 uppercase\">ME</span>\n        <div class=\"bg-[#004C97] text-white rounded-2xl rounded-tr-sm px-4 py-3 text-sm leading-relaxed shadow-xs\">\n          ${text}\n        </div>\n      `;\n      chatContainer.appendChild(msgDiv);\n      scrollChatToBottom();\n    }\n\n    function appendAIMessage(text) {\n      const msgDiv = document.createElement(\"div\");\n      msgDiv.className = \"flex flex-col gap-1 items-start text-left max-w-[85%] self-start animate-fade-in animate-slide-up\";\n      msgDiv.innerHTML = `\n        <span class=\"text-[10px] text-slate-400 font-bold ml-1 tracking-wider uppercase flex items-center gap-1\">\n          \342\234\250 MatchMood AI \342\200\242 Gemini 1.5 Flash\n        </span>\n        <div class=\"bg-slate-100 text-slate-800 rounded-2xl rounded-tl-sm px-4 py-3 text-sm leading-relaxed shadow-xs border border-slate-200/50\">\n          ${text}\n        </div>\n      `;\n      chatContainer.appendChild(msgDiv);\n      scrollChatToBottom();\n      checkMapTriggerFromText(text);\n    }\n\n    function showTypingIndicator() {\n      const indicator = document.createElement(\"div\");\n      indicator.id = \"help-chat-typing-indicator\";\n      indicator.className = \"flex flex-col gap-1 items-start text-left max-w-[85%] self-start animate-fade-in\";\n      indicator.innerHTML = `\n        <span class=\"text-[10px] text-slate-400 font-bold ml-1 tracking-wider uppercase\">\342\234\250 MatchMood AI</span>\n        <div class=\"bg-slate-100 border border-slate-200/50 rounded-2xl rounded-tl-sm px-4 py-3 flex items-center justify-center gap-1.5 shadow-xs\">\n          <div class=\"w-2 h-2 rounded-full bg-[#004C97] animate-typing-1\"></div>\n          <div class=\"w-2 h-2 rounded-full bg-[#004C97] animate-typing-2\"></div>\n          <div class=\"w-2 h-2 rounded-full bg-[#004C97] animate-typing-3\"></div>\n        </div>\n      `;\n      chatContainer.appendChild(indicator);\n      scrollChatToBottom();\n    }\n\n    function removeTypingIndicator() {\n      const indicator = document.getElementById(\"help-chat-typing-indicator\");\n      if (indicator) {\n        indicator.parentElement.removeChild(indicator);\n      }\n    }\n\n    // Handles help messaging flow\n    async function handleUserQuery(inputText) {\n      if (!inputText.trim() || isRequesting) return;\n      \n      isRequesting = true;\n      appendUserMessage(inputText);\n      showTypingIndicator();\n\n      const sysPrompt = `You are MatchMood AI, a smart and friendly stadium navigator for the MI vs RR IPL match at Wankhede Stadium, Mumbai. Help fans find gates, seats, food stalls, restrooms, and exits. Reply in maximum 3 short lines. Be warm, precise, and always add one helpful bonus tip. Only use these gates: Gate 1 (West), Gate 2 (South), Gate 3 (North-East), Gate 4 (South-East). Never invent locations.`;\n\n      try {\n        const responseText = await fetchGeminiAPI(inputText, sysPrompt);\n        removeTypingIndicator();\n        appendAIMessage(responseText);\n      } catch (err) {\n        removeTypingIndicator();\n        if (err.message === \"TIMEOUT\") {\n          // Toast timeout option\n          appendAIMessage(\"Taking longer than usual... tap to retry\");\n          showToast(\"\342\217\263 Request timed out. Please retry!\");\n        } else {\n          appendAIMessage(\"MatchMood AI is catching its breath, try again! \360\237\231\217\");\n          showToast(\"\342\235\214 Unable to connect to Gemini API. Check key/connection!\");\n        }\n      } finally {\n        isRequesting = false;\n      }\n    }\n\n    // Send Shortcut trigger\n    function sendShortcut(title, prompt) {\n      handleUserQuery(prompt);\n    }\n\n    // Chat submit events\n    const helpChatSendBtn = document.getElementById(\"help-chat-send\");\n    const helpChatInputEl = document.getElementById(\"help-chat-input\");\n\n    helpChatSendBtn.addEventListener(\"click\", () => {\n      const q = helpChatInputEl.value.trim();\n      if (q) {\n        handleUserQuery(q);\n        helpChatInputEl.value = \"\";\n      }\n    });\n\n    helpChatInputEl.addEventListener(\"keypress\", (e) => {\n      if (e.key === \"Enter\") {\n        const q = helpChatInputEl.value.trim();\n        if (q) {\n          handleUserQuery(q);\n          helpChatInputEl.value = \"\";\n        }\n      }\n    });\n\n\n    // ==============================================\n    // FAN ZONE INTERACTIONS\n    // ==============================================\n\n    const wicketBtn = document.getElementById(\"wicket-btn\");\n    const sixBtn = document.getElementById(\"six-btn\");\n    const chantBtn = document.getElementById(\"chant-btn\");\n    \n    const reactionCard = document.getElementById(\"dynamic-reaction-card\");\n    const reactionTypeBadge = document.getElementById(\"reaction-type-badge\");\n    const reactionTextEl = document.getElementById(\"reaction-text\");\n    const copyChantContainer = document.getElementById(\"copy-chant-container\");\n    const copyChantBtn = document.getElementById(\"copy-chant-btn\");\n    const copyFeedback = document.getElementById(\"copy-feedback-label\");\n\n    const fanSystemPrompt = `You are MatchMood AI, an ultra-hype cricket fan AI at MI vs RR IPL match. Be short (1-2 sentences), loud, energetic, use cricket slang. For wicket reactions: scream excitement. For six reactions: go wild. For chants: write exactly 4 rhyming lines for Mumbai Indians. For predictions: give a bold funny prediction with a win % for MI. Always sign off with \360\237\222\231 MatchMood AI`;\n\n    let activeChantValue = \"\";\n\n    function showReactionLoading(type) {\n      reactionCard.classList.remove(\"hidden\");\n      copyChantContainer.classList.add(\"hidden\");\n      \n      // Card text border coloring\n      reactionCard.className = \"bg-white rounded-2xl shadow-sm border border-slate-100 p-4 transition-all duration-300 transform scale-100\";\n      \n      if (type === \"Wicket\") {\n        reactionTypeBadge.textContent = \"\360\237\217\217 OUT!\";\n        reactionTypeBadge.className = \"text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider bg-red-100 text-red-700 border border-red-200\";\n        reactionTextEl.className = \"text-slate-800 text-sm font-semibold italic border-l-4 border-red-500 pl-3 py-1\";\n      } else if (type === \"Six\") {\n        reactionTypeBadge.textContent = \"\360\237\222\245 SIX!\";\n        reactionTypeBadge.className = \"text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider bg-blue-100 text-blue-700 border border-blue-200\";\n        reactionTextEl.className = \"text-slate-800 text-sm font-semibold italic border-l-4 border-blue-500 pl-3 py-1\";\n      } else {\n        reactionTypeBadge.textContent = \"\360\237\216\265 MI Chant\";\n        reactionTypeBadge.className = \"text-[9px] px-2 py-0.5 rounded-full font-bold uppercase tracking-wider bg-amber-100 text-amber-700 border border-amber-200\";\n        reactionTextEl.className = \"text-slate-800 text-sm font-semibold italic border-l-4 border-amber-500 pl-3 py-1\";\n      }\n\n      reactionTextEl.innerHTML = `\n        <div class=\"flex items-center gap-1.5 font-mono text-xs text-slate-400\">\n          <span>Writing hype...</span>\n          <div class=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-typing-1\"></div>\n          <div class=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-typing-2\"></div>\n          <div class=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-typing-3\"></div>\n        </div>\n      `;\n    }\n\n    async function handleFanButton(type, prompt) {\n      if (isRequesting) return;\n      isRequesting = true;\n      showReactionLoading(type);\n\n      try {\n        const responseText = await fetchGeminiAPI(prompt, fanSystemPrompt);\n        \n        // Setup reaction styling based on return block\n        if (type === \"Wicket\") {\n          reactionCard.className = \"bg-red-50/50 rounded-2xl shadow-sm border border-red-100 p-4 transition-all duration-300\";\n        } else if (type === \"Six\") {\n          reactionCard.className = \"bg-blue-50/50 rounded-2xl shadow-sm border border-blue-100 p-4 transition-all duration-300\";\n        } else {\n          reactionCard.className = \"bg-amber-50/50 rounded-2xl shadow-sm border border-amber-100 p-4 transition-all duration-300\";\n          activeChantValue = responseText;\n          copyChantContainer.classList.remove(\"hidden\");\n        }\n\n        reactionTextEl.innerHTML = responseText.replace(/\\n/g, \"<br>\");\n      } catch (err) {\n        reactionCard.classList.add(\"hidden\");\n        if (err.message === \"TIMEOUT\") {\n          showToast(\"\342\217\263 Take longer... retry tapping!\");\n        } else {\n          showToast(\"\342\235\214 Catching its breath. Please try again!\");\n        }\n      } finally {\n        isRequesting = false;\n      }\n    }\n\n    wicketBtn.addEventListener(\"click\", () => {\n      triggerConfetti();\n      handleFanButton(\"Wicket\", \"Give a wild hype reaction for a WICKET that fell!\");\n    });\n\n    sixBtn.addEventListener(\"click\", () => {\n      triggerFireworks();\n      handleFanButton(\"Six\", \"Give a highly-energized explosive reaction for a SIX that was smashed!\");\n    });\n\n    chantBtn.addEventListener(\"click\", () => {\n      handleFanButton(\"Chant\", \"Write exactly 4 rhyming lines chant in support of Mumbai Indians. Energetic loud, clean rhythm, ready to copy paste!\");\n    });\n\n    // Copy to clipboard chant routine\n    copyChantBtn.addEventListener(\"click\", () => {\n      if (!activeChantValue) return;\n      navigator.clipboard.writeText(activeChantValue).then(() => {\n        // Flash Copied state\n        copyFeedback.style.opacity = \"1\";\n        setTimeout(() => {\n          copyFeedback.style.opacity = \"0\";\n        }, 2000);\n      }).catch(err => {\n        showToast(\"\342\232\240\357\270\217 Unable to copy chant automatically.\");\n      });\n    });\n\n\n    // ==============================================\n    // PREDICTOR SYSTEM MATCH CONTROLS\n    // ==============================================\n\n    const predictBtn = document.getElementById(\"predict-btn\");\n    const predictInput = document.getElementById(\"predict-input\");\n    \n    const predictLoader = document.getElementById(\"predict-loader\");\n    const predictOutput = document.getElementById(\"predict-output\");\n    const predictText = document.getElementById(\"predict-text\");\n    const winPctBadge = document.getElementById(\"win-pct-badge\");\n\n    predictBtn.addEventListener(\"click\", async () => {\n      if (isRequesting) return;\n      \n      const customInput = predictInput.value.trim();\n      const finalPrompt = customInput \n        ? `Given context: \"${customInput}\". Predict who wins Mumbai Indians vs Rajasthan Royals and provide win % probability percentage for MI in single-sentence funny fan output.`\n        : `MI 142/4 (16.2 ov). Predict who wins Mumbai Indians vs Rajasthan Royals and provide win probability % percentage for MI with extremely funny fan prediction.`;\n\n      isRequesting = true;\n      predictLoader.classList.remove(\"hidden\");\n      predictOutput.classList.add(\"hidden\");\n\n      try {\n        const responseText = await fetchGeminiAPI(finalPrompt, fanSystemPrompt);\n        \n        predictLoader.classList.add(\"hidden\");\n        predictOutput.classList.remove(\"hidden\");\n        predictOutput.classList.add(\"animate-fade-in\");\n        \n        predictText.textContent = responseText;\n\n        // Try to parse WIN match percentages dynamically or default to a cool estimate\n        const pctRegex = /(\\d+)%/;\n        const match = responseText.match(pctRegex);\n        if (match && match[1]) {\n          winPctBadge.textContent = `MI Chance: ${match[1]}%`;\n        } else {\n          // Generate a random-looking hot dynamic estimate 50% to 90%\n          const mockPct = Math.floor(Math.random() * 41) + 50; \n          winPctBadge.textContent = `MI Chance: ${mockPct}%`;\n        }\n\n      } catch (err) {\n        predictLoader.classList.add(\"hidden\");\n        if (err.message === \"TIMEOUT\") {\n          showToast(\"\342\217\263 Timeout - prediction took too long!\");\n        } else {\n          showToast(\"\342\235\214 Unable to fetch prediction analysis!\");\n        }\n      } finally {\n        isRequesting = false;\n      }\n    });\n\n  </script>\n</body>\n</html>"
    }
