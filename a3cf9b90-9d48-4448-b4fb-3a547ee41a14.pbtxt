        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Canvas configuration for Confetti / Fireworks"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const canvas = document.getElementById(\"effects-canvas\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const ctx = canvas.getContext(\"2d\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let animationFrameId = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let particles = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let waves = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Resize canvas to match container frame context scale"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function resizeCanvas() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const parent = canvas.parentElement;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      canvas.width = parent.clientWidth;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      canvas.height = parent.clientHeight;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    window.addEventListener(\"resize\", resizeCanvas);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Initial resize inside frame context"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    setTimeout(resizeCanvas, 3000);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // RequestAnimationFrame Game Loop"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function updateEffects() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ctx.clearRect(0, 0, canvas.width, canvas.height);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Update particles"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      particles = particles.filter(p => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p.x += p.vx;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p.y += p.vy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p.vy += p.gravity;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p.alpha -= p.fade;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p.rotation += p.rotationSpeed;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (p.alpha <= 0 || p.y > canvas.height) return false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.save();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.translate(p.x, p.y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.rotate(p.rotation);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.fillStyle = p.color;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (p.isSpark) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          // Draw firework star lines"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.strokeStyle = p.color;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.lineWidth = p.lineWidth || 2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.beginPath();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.moveTo(-p.size, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.lineTo(p.size, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.stroke();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          // Draw Confetti shapes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.restore();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (particles.length > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        animationFrameId = requestAnimationFrame(updateEffects);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        animationFrameId = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ctx.clearRect(0, 0, canvas.width, canvas.height);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function triggerConfetti() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      resizeCanvas();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      particles = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const colors = [\"#004C97\", \"#D4AF37\", \"#E91E8C\", \"#E53935\", \"#1565C0\", \"#F9A825\", \"#4ADE80\", \"#C084FC\"];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const particleCount = 80;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let i = 0; i < particleCount; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Spawn particles towards bottom center blowing upwards"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        particles.push({"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          x: canvas.width / 2 + (Math.random() * 60 - 30),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          y: canvas.height * 0.9,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          vx: Math.random() * 8 - 4,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          vy: -(Math.random() * 12 + 8),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          gravity: 0.35,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          alpha: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          fade: Math.random() * 0.005 + 0.005,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          rotation: Math.random() * Math.PI * 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          rotationSpeed: Math.random() * 0.1 - 0.05,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          color: colors[Math.floor(Math.random() * colors.length)],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          size: Math.random() * 8 + 6,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          isSpark: false"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (!animationFrameId) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        animationFrameId = requestAnimationFrame(updateEffects);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function triggerFireworks() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      resizeCanvas();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      particles = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const colors = [\"#004C97\", \"#D4AF37\", \"#E91E8C\", \"#1565C0\", \"#F9A825\", \"#ffffff\"];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const burstX = canvas.width / 2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const burstY = canvas.height * 0.45; // Burst center"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const rayCount = 12;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let j = 0; j < 3; j++) { // Multi layered bursts"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const baseColor = colors[Math.floor(Math.random() * colors.length)];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const velocityScale = 3.5 + (j * 1.5);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        for (let i = 0; i < rayCount; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const angle = (i * Math.PI * 2) / rayCount;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          particles.push({"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            x: burstX,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            y: burstY,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            vx: Math.cos(angle) * (Math.random() * 2 + velocityScale),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            vy: Math.sin(angle) * (Math.random() * 2 + velocityScale),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            gravity: 0.1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            alpha: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            fade: 0.015 + (Math.random() * 0.005),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            rotation: angle,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            rotationSpeed: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            color: baseColor,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            size: Math.random() * 10 + 8,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            isSpark: true,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            lineWidth: 2.5"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (!animationFrameId) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        animationFrameId = requestAnimationFrame(updateEffects);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // API Key Storage & Handling"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const saveKeyBtn = document.getElementById(\"save-key-btn\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const changeKeyBtn = document.getElementById(\"change-key-btn\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const apiKeyInput = document.getElementById(\"api-key-input\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const apiKeysContainer = document.getElementById(\"api-key-container\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const apiKeyWrapper = document.getElementById(\"api-key-input-wrapper\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const apiReadyWrapper = document.getElementById(\"api-ready-wrapper\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function loadSavedKey() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const savedKey = localStorage.getItem(\"matchmood_api_key\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Also check platform env backup"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const envKey = \"GEMINI_API_KEY_ENV\"; "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (savedKey) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        api_key = savedKey;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        setKeyReadyUI();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // If not explicit in client, don\'t auto crash but show input key bar"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        setKeyInputUI();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function setKeyReadyUI() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      apiKeyWrapper.classList.add(\"hidden\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      apiReadyWrapper.classList.remove(\"hidden\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    function setKeyInputUI() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      apiKeyWrapper.classList.remove(\"hidden\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      apiReadyWrapper.classList.add(\"hidden\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      apiKeyInput.value = api_key;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    saveKeyBtn.addEventListener(\"click\", () => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const keyInput = apiKeyInput.value.trim();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (!keyInput) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        showToast(\"\360\237\224\221 Please enter a valid Gemini API key!\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      api_key = keyInput;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      localStorage.setItem(\"matchmood_api_key\", keyInput);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      setKeyReadyUI();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    changeKeyBtn.addEventListener(\"click\", () => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
