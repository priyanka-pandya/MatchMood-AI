        }
        lines {
          text: "        helpBtn.style.opacity = \"0.4\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        helpBtn.querySelector(\"span:last-child\").style.color = \"#64748b\";"
